{
  "name": "@rimotli-tech/rive-telemetry",
  "displayName": "Rive Telemetry JS",
  "description": "Debug Rive animations in JavaScript from VS Code by inspecting and controlling state machine inputs and ViewModel properties.",
  "version": "0.3.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "app": "vite --host 127.0.0.1",
    "app:build": "vite build",
    "build": "tsc -p ./",
    "check": "tsc --noEmit -p ./",
    "test": "npm run build && node --test \"test/**/*.test.js\""
  },
  "keywords": [
    "rive",
    "animation",
    "debug",
    "devtools",
    "telemetry",
    "viewmodel",
    "vscode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Rimotli-tech/rive_telemetry",
    "directory": "js"
  },
  "bugs": {
    "url": "https://github.com/Rimotli-tech/rive_telemetry/issues"
  },
  "homepage": "https://github.com/Rimotli-tech/rive_telemetry",
  "license": "MIT",
  "peerDependencies": {
    "@rive-app/canvas": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@rive-app/canvas": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rive-app/canvas": "^2.31.2",
    "vite": "^7.1.12",
    "typescript": "^5.9.3"
  }
}
