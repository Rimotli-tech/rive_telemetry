{
  "name": "rive-telemetry",
  "displayName": "Rive Telemetry",
  "description": "Inspect and control Rive runtime behavior from VS Code.",
  "version": "0.3.1",
  "publisher": "rimotli-tech",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Debuggers"
  ],
  "keywords": [
    "rive",
    "flutter",
    "animation",
    "debug",
    "devtools",
    "telemetry",
    "viewmodel"
  ],
  "activationEvents": [
    "onCommand:riveTelemetry.openPanel",
    "onCommand:riveTelemetry.inspectFile",
    "onCommand:riveTelemetry.reloadFile",
    "onCommand:riveTelemetry.exportMetadata",
    "onCommand:riveTelemetry.generateFlutterIntegration",
    "onCommand:riveTelemetry.createMetadataDeliverable"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "riveTelemetry.openPanel",
        "title": "RiveTelemetry: Open Panel"
      },
      {
        "command": "riveTelemetry.inspectFile",
        "title": "RiveTelemetry: Inspect .riv File"
      },
      {
        "command": "riveTelemetry.reloadFile",
        "title": "RiveTelemetry: Reload Current .riv File"
      },
      {
        "command": "riveTelemetry.exportMetadata",
        "title": "RiveTelemetry: Export Metadata JSON"
      },
      {
        "command": "riveTelemetry.generateFlutterIntegration",
        "title": "RiveTelemetry: Generate Flutter Integration"
      },
      {
        "command": "riveTelemetry.createMetadataDeliverable",
        "title": "RiveTelemetry: Create Metadata Deliverable"
      }
    ],
    "configuration": {
      "title": "RiveTelemetry",
      "properties": {
        "riveTelemetry.port": {
          "type": "number",
          "default": 8080,
          "minimum": 1,
          "maximum": 65535,
          "description": "Local WebSocket port used by the RiveTelemetry VS Code extension."
        },
        "riveTelemetry.dartPath": {
          "type": "string",
          "default": "dart",
          "description": "Dart executable used by the RiveTelemetry .riv metadata inspector. Set this to an absolute dart or dart.exe path if VS Code cannot find Dart on PATH."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "check": "tsc --noEmit -p ./",
    "test": "npm run compile && node --test \"test/**/*.test.js\""
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/ws": "^8.5.13",
    "@types/vscode": "^1.118.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Rimotli-tech/rive_telemetry"
  },
  "bugs": {
    "url": "https://github.com/Rimotli-tech/rive_telemetry/issues"
  },
  "homepage": "https://github.com/Rimotli-tech/rive_telemetry",
  "license": "MIT"
}
