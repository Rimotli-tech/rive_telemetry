{
  "name": "rive-telemetry",
  "displayName": "Rive Telemetry",
  "description": "Inspect and control Rive runtime behavior from VS Code.",
  "version": "0.3.0",
  "publisher": "local",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Debuggers"
  ],
  "keywords": [
    "rive",
    "flutter",
    "animation",
    "debug",
    "devtools",
    "telemetry",
    "viewmodel"
  ],
  "activationEvents": [
    "onCommand:riveTelemetry.openPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "riveTelemetry.openPanel",
        "title": "RiveTelemetry: Open Panel"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "check": "tsc --noEmit -p ./"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/ws": "^8.5.13",
    "@types/vscode": "^1.118.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Rimotli-tech/rive_telemetry"
  },
  "bugs": {
    "url": "https://github.com/Rimotli-tech/rive_telemetry/issues"
  },
  "homepage": "https://github.com/Rimotli-tech/rive_telemetry",
  "license": "MIT"
}
